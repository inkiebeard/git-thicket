{
  "name": "thicket",
  "description": "A lightweight, cross-platform git tree viewer built with Tauri and React",
  "author": {
    "email": "aaron@inkiebeard.codes",
    "name": "Aaron Toomey"
  },
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:prod": "tauri build",
    "build:prod:macos": "tauri build --target universal-apple-darwin",
    "build:prod:macos:intel": "tauri build --target x86_64-apple-darwin",
    "build:prod:macos:arm": "tauri build --target aarch64-apple-darwin",
    "build:prod:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:prod:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "version": "node scripts/sync-version.mjs && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
